    "globals": "^16.5.0",
    "jiti": "^2.6.1",
    "nodemon": "^3.0.1",
    "ts-node": "^10.9.2"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
